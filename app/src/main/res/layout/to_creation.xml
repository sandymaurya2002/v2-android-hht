                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Crate" android:textSize="15sp" />
                    <EditText android:id="@+id/crate_no" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1.3" android:hint="Crate No" android:imeOptions="actionSearch" android:inputType="text" android:maxLines="1" android:singleLine="true" android:textSize="15sp" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:text="PO" android:textSize="15sp" />
                    <EditText android:layout_weight="1.3" android:textSize="15sp" android:id="@+id/po" android:layout_width="0dp" android:layout_height="48dp" android:hint="Scan PO" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Dest Bin" android:textSize="15sp" />
                    <EditText android:id="@+id/dest_bin" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1.3" android:hint="Dest. Bin" android:imeOptions="actionSearch" android:inputType="text" android:maxLines="1" android:singleLine="true" android:textSize="15sp" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Total Scanned" android:textSize="15sp" />
                    <EditText android:layout_weight="1.3" android:textSize="15sp" android:id="@+id/ts" android:layout_width="0dp" android:layout_height="48dp" android:hint="Total Scanned" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Crate Qty" android:textSize="15sp" />
                    <EditText android:layout_weight="1.3" android:textSize="15sp" android:id="@+id/cq" android:layout_width="0dp" android:layout_height="48dp" android:hint="Crate QTY" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Total Crate Qty" android:textSize="15sp" />
                    <EditText android:layout_weight="1.3" android:textSize="15sp" android:id="@+id/tcq" android:layout_width="0dp" android:layout_height="48dp" android:hint="Bin No." android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
