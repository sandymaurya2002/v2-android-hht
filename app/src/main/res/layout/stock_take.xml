<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_margin="2dp" android:padding="5dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_weight=".9" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Pack Mat" android:textSize="15sp" />
                <Spinner android:layout_weight="1.5" android:textSize="15sp" android:id="@+id/pack_mat_spinner" android:layout_width="0dp" android:entries="@array/choose_store" android:layout_height="wrap_content" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_weight=".9" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Article/Barcode" android:textSize="15sp" />
                <EditText android:layout_weight="1" android:textSize="15sp" android:id="@+id/barcode_no" android:layout_width="0dp" android:layout_height="48dp" android:hint="Barcode No." android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                <Button android:layout_weight="0.5" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Scan" android:id="@+id/barcode_scan" android:layout_margin="2dp" android:padding="2dp" android:background="@drawable/bg_btn_primary" android:textColor="@color/white" android:textSize="13sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_weight=".9" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Article No" android:textSize="15sp" />
                <EditText android:layout_weight="1.5" android:textSize="15sp" android:id="@+id/article_no" android:layout_width="0dp" android:layout_height="48dp" android:hint="Acticle No." android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_weight=".9" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Article Avl Stock" android:layout_gravity="center" android:textSize="15sp" />
                <EditText android:layout_weight="1.5" android:textSize="15sp" android:id="@+id/article_available_stock" android:layout_width="0dp" android:layout_height="48dp" android:hint="Article Available Stock" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_weight=".9" android:layout_width="0dp" android:layout_height="wrap_content" android:text="A.S.Q/T.S.Q" android:textSize="15sp" />
                <EditText android:layout_weight=".75" android:textSize="15sp" android:id="@+id/asq" android:layout_width="0dp" android:layout_height="48dp" android:hint="A.S.Q" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                <EditText android:layout_weight=".75" android:textSize="15sp" android:id="@+id/tsq" android:layout_width="0dp" android:layout_height="48dp" android:hint="T.S.Q" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_weight=".9" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Total Scan Qty" android:textSize="15sp" />
                <EditText android:layout_weight="1.5" android:textSize="15sp" android:id="@+id/total_scan_qty" android:layout_width="0dp" android:layout_height="48dp" android:hint="Total Scan Qty" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
            <Button android:layout_weight="1.5" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Back" android:id="@+id/back" android:background="@drawable/bg_btn_primary" android:layout_margin="2dp" android:textSize="15sp" android:textColor="@color/white" />
            <Button android:layout_weight="1.5" android:textSize="15sp" android:text="Save" android:id="@+id/save" android:background="@drawable/bg_btn_primary" android:layout_margin="2dp" android:layout_width="0dp" android:layout_height="wrap_content" android:hint="" android:textColor="@color/white" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>