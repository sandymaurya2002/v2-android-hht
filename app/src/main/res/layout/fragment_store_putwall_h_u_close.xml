<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bgPage">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="12dp" android:paddingBottom="12dp"
        android:background="@color/bgCard">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="HU close" android:textSize="16sp" android:textStyle="bold"
                android:textColor="@color/textPrimary" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Close HU after putway" android:textSize="11sp" android:textColor="@color/textLabel" />
        </LinearLayout>
        <TextView android:id="@+id/tv_error_badge" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:visibility="gone"
            android:textSize="10sp" android:textStyle="bold" android:text="Error"
            android:textColor="@color/colorError" android:background="@color/colorErrorBg"
            android:paddingStart="10dp" android:paddingEnd="10dp"
            android:paddingTop="4dp" android:paddingBottom="4dp" />
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <LinearLayout android:id="@+id/layout_error_banner"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@color/colorErrorBg" android:padding="12dp"
                android:layout_marginBottom="12dp" android:gravity="center_vertical"
                android:visibility="gone">
                <TextView android:id="@+id/tv_error_message" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textSize="11sp"
                    android:textStyle="bold" android:textColor="@color/colorError" />
            </LinearLayout>

            <!-- Scan Store -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@color/bgCard"
                android:padding="14dp" android:layout_marginBottom="10dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="SCAN STORE" android:textSize="10sp" android:textStyle="bold"
                    android:textColor="@color/textLabel" android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp" />
                <EditText android:id="@+id/et_store_code"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:background="@color/bgInput" android:textColor="@color/textPrimary"
                    android:textColorHint="@color/textHint" android:textSize="15sp" android:textStyle="bold"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:hint="Scan store barcode..." android:imeOptions="actionDone"
                    android:maxLines="1" android:singleLine="true" android:inputType="text" />
                <LinearLayout android:id="@+id/layout_store_ok"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="@color/colorSuccessBg" android:padding="10dp"
                    android:layout_marginTop="8dp" android:visibility="gone">
                    <TextView android:id="@+id/tv_store_name" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:textSize="11sp"
                        android:textStyle="bold" android:textColor="@color/colorSuccess" />
                </LinearLayout>
            </LinearLayout>

            <!-- Scan HU -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@color/bgCard"
                android:padding="14dp" android:layout_marginBottom="10dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="SCAN HU TO CLOSE" android:textSize="10sp" android:textStyle="bold"
                    android:textColor="@color/textLabel" android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp" />
                <EditText android:id="@+id/et_hu_code"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:background="@color/bgInput" android:textColor="@color/textPrimary"
                    android:textColorHint="@color/textHint" android:textSize="15sp" android:textStyle="bold"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:hint="Scan HU barcode..." android:imeOptions="actionDone"
                    android:maxLines="1" android:singleLine="true" android:inputType="text" />
                <LinearLayout android:id="@+id/layout_hu_ok"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="@color/colorSuccessBg" android:padding="10dp"
                    android:layout_marginTop="8dp" android:visibility="gone">
                    <TextView android:id="@+id/tv_hu_status" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:textSize="11sp"
                        android:textStyle="bold" android:textColor="@color/colorSuccess"
                        android:text="HU closed successfully" />
                </LinearLayout>
            </LinearLayout>

            <!-- HU Count stat -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@color/statGreenBg" android:padding="14dp"
                    android:layout_marginEnd="4dp">
                    <TextView android:id="@+id/tv_hu_closed_count"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="0" android:textSize="30sp" android:textStyle="bold"
                        android:textColor="@color/colorSuccess" android:letterSpacing="-0.04" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="HUs CLOSED" android:textSize="9sp" android:textStyle="bold"
                        android:textColor="@color/textLabel" android:letterSpacing="0.08"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="#F3E5F5" android:padding="14dp"
                    android:layout_marginStart="4dp">
                    <TextView android:id="@+id/tv_hu_pending_count"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="0" android:textSize="30sp" android:textStyle="bold"
                        android:textColor="#5B21B6" android:letterSpacing="-0.04" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="PENDING" android:textSize="9sp" android:textStyle="bold"
                        android:textColor="@color/textLabel" android:letterSpacing="0.08"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <Button android:id="@+id/btn_hu_close_back"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:layout_margin="14dp" android:text="Back"
        android:textColor="@color/textPrimary" android:textSize="13sp" android:textStyle="bold"
        android:background="@color/bgInput" />
</LinearLayout>