<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" tools:layout_editor_absoluteX="-122dp" tools:layout_editor_absoluteY="-16dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="2dp" android:orientation="vertical" android:padding="5dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight=".9" android:text="Article/Barcode" android:textSize="15sp" />
                <EditText android:id="@+id/barcode_no" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1.5" android:hint="Barcode No." android:imeOptions="actionSearch" android:inputType="text" android:lines="1" android:singleLine="true" android:textSize="15sp" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight=".9" android:text="Article No" android:textSize="15sp" />
                <EditText android:id="@+id/article_no" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1.5" android:enabled="true" android:focusable="false" android:hint="Article No." android:textSize="15sp" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_gravity="center" android:layout_weight=".9" android:text="Article Avl Stock" android:textSize="15sp" />
                <EditText android:id="@+id/article_available_stock" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1.5" android:enabled="true" android:focusable="false" android:hint="Article Available Stock" android:textSize="15sp" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_gravity="center" android:layout_weight=".9" android:text="Sub Div" android:textSize="15sp" />
                <EditText android:id="@+id/subDiv" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1.5" android:enabled="true" android:focusable="false" android:hint="Sub Div" android:textSize="15sp" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_gravity="center" android:layout_weight=".9" android:text="Art Type" android:textSize="15sp" />
                <EditText android:id="@+id/artType" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1.5" android:enabled="true" android:focusable="false" android:hint="Art Type" android:textSize="15sp" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight=".9" android:text="A.S.Q/T.S.Q" android:textSize="15sp" />
                <EditText android:id="@+id/asq" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight=".75" android:enabled="true" android:focusable="false" android:hint="A.S.Q" android:textSize="15sp" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                <EditText android:id="@+id/tsq" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight=".75" android:enabled="true" android:focusable="false" android:hint="T.S.Q" android:textSize="15sp" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight=".9" android:text="Total Scan Qty" android:textSize="15sp" />
                <EditText android:id="@+id/total_scan_qty" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1.5" android:enabled="true" android:focusable="false" android:hint="Total Scan Qty" android:textSize="15sp" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
            <TextView android:id="@+id/response" android:layout_width="match_parent" android:layout_height="60dp" android:layout_margin="2dp" android:padding="5dp" android:text="status:" android:textColor="@color/colorPrimary" android:visibility="gone" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
            <Button android:id="@+id/back" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_margin="2dp" android:layout_weight="1.5" android:background="@drawable/bg_btn_primary" android:text="Back" android:textSize="15sp" android:textColor="@color/white" />
            <Button android:id="@+id/save" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_margin="2dp" android:layout_weight="1.5" android:background="@drawable/bg_btn_primary" android:hint="" android:text="Save" android:textSize="15sp" android:textColor="@color/white" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>