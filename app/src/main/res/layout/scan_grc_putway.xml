<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent">
    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_margin="2dp" android:padding="5dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_weight=".9" android:layout_width="0dp" android:layout_height="wrap_content" android:text="HU No" android:textSize="15sp" />
                    <EditText android:layout_weight="1.5" android:textSize="15sp" android:id="@+id/hu_no" android:enabled="true" android:focusable="false" android:layout_width="0dp" android:layout_height="48dp" android:hint="HU No." android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_weight=".9" android:layout_width="0dp" android:layout_height="wrap_content" android:text="HU Total Qty" android:textSize="15sp" />
                    <EditText android:layout_weight="1.5" android:textSize="15sp" android:id="@+id/hu_total_qty" android:layout_width="0dp" android:enabled="true" android:focusable="false" android:layout_height="48dp" android:hint="HU Total Qty" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight=".9" android:text="Bin" android:textSize="15sp" />
                    <EditText android:id="@+id/bin_no" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1.5" android:hint="Enter Bin Name" android:imeOptions="actionSearch" android:inputType="text" android:maxLines="1" android:singleLine="true" android:textSize="15sp" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_weight=".9" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Article/Barcode" android:layout_gravity="center" android:textSize="15sp" />
                    <EditText android:layout_weight="1.5" android:textSize="15sp" android:id="@+id/barcode_et" android:layout_width="0dp" android:imeOptions="actionSearch" android:singleLine="true" android:inputType="number" android:lines="1" android:layout_height="48dp" android:hint="Barcode No." android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_weight=".9" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Article No" android:textSize="15sp" />
                    <EditText android:layout_weight="1.5" android:textSize="15sp" android:id="@+id/article_no" android:layout_width="0dp" android:enabled="true" android:focusable="false" android:layout_height="48dp" android:hint="EAN No." android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_weight=".9" android:layout_width="0dp" android:layout_height="wrap_content" android:text="A.H.Q/A.H.O.Q" android:textSize="15sp" />
                    <EditText android:layout_weight=".75" android:textSize="15sp" android:id="@+id/ahq" android:enabled="true" android:focusable="false" android:layout_width="0dp" android:layout_height="48dp" android:hint="A.H.Q" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                    <EditText android:layout_weight=".75" android:textSize="15sp" android:enabled="true" android:focusable="false" android:id="@+id/ahoq" android:layout_width="0dp" android:layout_height="48dp" android:hint="A.H.O.Q" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_weight=".9" android:layout_width="0dp" android:layout_height="wrap_content" android:text="S.Q/T.S.Q" android:textSize="15sp" />
                    <EditText android:layout_weight=".75" android:textSize="15sp" android:id="@+id/sq" android:enabled="true" android:focusable="false" android:layout_width="0dp" android:layout_height="48dp" android:hint="S.Q" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                    <EditText android:layout_weight=".75" android:textSize="15sp" android:id="@+id/tsq" android:enabled="true" android:focusable="false" android:layout_width="0dp" android:layout_height="48dp" android:hint="T.S.Q" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <TextView android:id="@+id/response" android:layout_width="match_parent" android:layout_height="60dp" android:layout_margin="2dp" android:padding="5dp" android:text="status:" android:visibility="gone" android:textColor="@color/colorPrimary" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <Button android:layout_weight="1.5" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Back" android:id="@+id/back" android:background="@drawable/bg_btn_primary" android:layout_margin="2dp" android:textSize="15sp" android:textColor="@color/white" />
                <Button android:layout_weight="1.5" android:textSize="15sp" android:text="Save" android:id="@+id/save" android:background="@drawable/bg_btn_primary" android:layout_margin="2dp" android:layout_width="0dp" android:layout_height="wrap_content" android:hint="" android:textColor="@color/white" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>