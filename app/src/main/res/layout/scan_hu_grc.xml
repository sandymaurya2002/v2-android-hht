<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="5dp" android:layout_margin="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_weight=".8" android:layout_width="0dp" android:layout_height="wrap_content" android:text="TTL HU" android:textSize="15sp" />
                <EditText android:layout_weight="1.8" android:textSize="15sp" android:id="@+id/ttl_hu" android:layout_width="0dp" android:enabled="true" android:focusable="false" android:layout_height="48dp" android:hint="TTL HU" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_weight=".8" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Scan HU" android:textSize="15sp" />
                <EditText android:layout_weight="1.8" android:textSize="15sp" android:id="@+id/scan_hu_no" android:layout_width="0dp" android:imeOptions="actionSearch" android:singleLine="true" android:inputType="number" android:lines="1" android:layout_height="48dp" android:hint="HU number" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_weight=".8" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Short HU" android:textSize="15sp" />
                <EditText android:layout_weight="1.8" android:textSize="15sp" android:id="@+id/short_hu" android:enabled="true" android:focusable="false" android:layout_width="0dp" android:layout_height="48dp" android:hint="Short HU" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_weight=".8" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Excess HU" android:layout_gravity="center" android:textSize="15sp" />
                <EditText android:layout_weight="1.8" android:textSize="15sp" android:layout_gravity="center" android:id="@+id/excess_hu" android:enabled="true" android:focusable="false" android:layout_width="0dp" android:layout_height="48dp" android:hint="Excess HU" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
            <TextView android:id="@+id/response" android:layout_width="match_parent" android:layout_height="60dp" android:layout_margin="2dp" android:padding="5dp" android:text="status:" android:visibility="gone" android:textColor="@color/colorPrimary" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
            <Button android:layout_weight="1.8" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Back" android:id="@+id/back" android:background="@drawable/bg_btn_primary" android:layout_margin="2dp" android:textSize="15sp" android:textColor="@color/white" />
            <Button android:layout_weight="1.8" android:textSize="15sp" android:text="Save" android:id="@+id/save" android:background="@drawable/bg_btn_primary" android:layout_margin="2dp" android:layout_width="0dp" android:layout_height="wrap_content" android:hint="" android:textColor="@color/white" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>