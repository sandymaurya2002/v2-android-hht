<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="5dp" android:layout_margin="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <TextView android:layout_weight=".6" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Article No." android:textSize="15sp" />
                <EditText android:layout_weight=".8" android:textSize="15sp" android:id="@+id/barcode" android:inputType="number" android:layout_width="0dp" android:imeOptions="actionSearch" android:singleLine="true" android:lines="1" android:layout_height="48dp" android:hint="Scan Barcode" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                <Button android:layout_weight=".6" android:textSize="15sp" android:text="Scan" android:id="@+id/bar_scan" android:background="@drawable/bg_btn_primary" android:layout_margin="2dp" android:layout_width="0dp" android:layout_height="wrap_content" android:hint="" android:textColor="@color/white" />
            </LinearLayout>
            <TextView android:id="@+id/response" android:layout_width="match_parent" android:layout_height="60dp" android:layout_margin="2dp" android:padding="5dp" android:text="status:" android:visibility="gone" android:textColor="@color/colorPrimary" />
        </LinearLayout>
        &gt;

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
            <Button android:layout_weight="0.6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Back" android:id="@+id/back" android:background="@drawable/bg_btn_primary" android:layout_margin="8dp" android:textSize="15sp" android:textColor="@color/white" />
            <Button android:layout_weight="0.6" android:textSize="15sp" android:text="Search" android:id="@+id/search" android:background="@drawable/bg_btn_primary" android:layout_margin="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:hint="" android:textColor="@color/white" />
            <Button android:layout_weight="0.6" android:textSize="15sp" android:text="Re-Scan" android:id="@+id/rescan" android:background="@drawable/bg_btn_primary" android:layout_margin="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:hint="" android:textColor="@color/white" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>