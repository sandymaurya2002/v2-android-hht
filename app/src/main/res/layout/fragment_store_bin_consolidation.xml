<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent" android:layout_height="match_parent" tools:context=".store.StoreBinConsolidationFragment" android:background="@color/bgPage">
    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_margin="2dp" android:padding="5dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_weight=".9" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Store" android:textSize="15sp" />
                    <EditText android:layout_weight="1.5" android:textSize="15sp" android:id="@+id/storeEt" android:enabled="true" android:focusable="false" android:layout_width="0dp" android:layout_height="48dp" android:hint="Store" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_weight=".9" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Pick List" android:textSize="15sp" />
                    <EditText android:layout_weight="1.5" android:textSize="15sp" android:id="@+id/pickListEt" android:enabled="true" android:layout_width="0dp" android:imeOptions="actionDone" android:inputType="number" android:layout_height="48dp" android:hint="Pick List" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_weight=".9" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Date" android:textSize="15sp" />
                    <EditText android:layout_weight="1.5" android:textSize="15sp" android:id="@+id/dateEt" android:enabled="true" android:focusable="false" android:layout_width="0dp" android:layout_height="48dp" android:hint="Date" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="next" android:id="@+id/next" android:background="@drawable/bg_btn_primary" android:layout_marginRight="10dp" android:layout_gravity="end" android:textColor="@color/white" android:textSize="13sp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_weight=".9" android:layout_width="0dp" android:layout_height="wrap_content" android:text="HU No" android:textSize="15sp" />
                    <EditText android:layout_weight="1.5" android:textSize="15sp" android:id="@+id/hu_no" android:enabled="false" android:layout_width="0dp" android:inputType="number" android:layout_height="48dp" android:hint="HU No." android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight=".9" android:text="Bin" android:textSize="15sp" />
                    <EditText android:id="@+id/bin_no" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1.5" android:hint="Enter Bin Name" android:imeOptions="actionSearch" android:inputType="text" android:enabled="false" android:maxLines="1" android:singleLine="true" android:textSize="15sp" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_weight=".9" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Barcode" android:layout_gravity="center" android:textSize="15sp" />
                    <EditText android:layout_weight="1.5" android:textSize="15sp" android:id="@+id/barcode_et" android:layout_width="0dp" android:imeOptions="actionSearch" android:singleLine="true" android:enabled="false" android:inputType="number" android:lines="1" android:layout_height="48dp" android:hint="Barcode" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_weight=".9" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Article No" android:textSize="15sp" />
                    <EditText android:id="@+id/article_no" android:layout_width="0dp" android:layout_height="51dp" android:layout_weight="1.5" android:enabled="true" android:focusable="false" android:hint="Article No." android:textSize="15sp" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_weight=".9" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Bin Scan Qty" android:textSize="15sp" />
                    <EditText android:layout_weight="1.5" android:textSize="15sp" android:id="@+id/bsqEt" android:enabled="true" android:focusable="false" android:layout_width="0dp" android:layout_height="48dp" android:hint="Bin Qty" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                    <TextView android:layout_weight=".9" android:layout_width="0dp" android:layout_height="wrap_content" android:text="T.S.Q" android:textSize="15sp" />
                    <EditText android:layout_weight="1.5" android:textSize="15sp" android:id="@+id/sqEt" android:enabled="true" android:focusable="false" android:layout_width="0dp" android:layout_height="48dp" android:hint="Total Scan" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
                </LinearLayout>
                <TextView android:id="@+id/response" android:layout_width="match_parent" android:layout_height="60dp" android:layout_margin="2dp" android:padding="5dp" android:text="status:" android:visibility="gone" android:textColor="@color/colorPrimary" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="5dp">
                <Button android:layout_weight="1.5" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Back" android:id="@+id/back" android:background="@drawable/bg_btn_primary" android:layout_margin="2dp" android:textSize="15sp" android:textColor="@color/white" />
                <Button android:layout_weight="1.5" android:textSize="15sp" android:text="Save" android:id="@+id/save" android:background="@drawable/bg_btn_primary" android:layout_margin="2dp" android:layout_width="0dp" android:layout_height="wrap_content" android:hint="" android:textColor="@color/white" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>