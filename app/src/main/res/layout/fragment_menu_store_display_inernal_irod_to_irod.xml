<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:id="@+id/displayInternalIrodToIrodMenu">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="2dp"
            android:background="@color/black"
            android:padding="5dp"
            android:tag="store_display_tag">

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:textColor="@color/white"
                android:id="@+id/store_display_internal_irod_to_irod_picking"
                android:background="@color/buttonColor"
                android:text="Picking" />
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:textColor="@color/white"
                android:id="@+id/store_display_internal_irod_to_irod_putway"
                android:background="@color/buttonColor"
                android:text="Putway" />
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:textColor="@color/white"
                android:id="@+id/store_display_internal_irod_to_irod_empty"
                android:background="@color/buttonColor"
                android:text="IROD Empty" />
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:textColor="@color/white"
                android:id="@+id/store_display_internal_irod_to_irod_transfer"
                android:background="@color/buttonColor"
                android:text="Transfer IROD" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>