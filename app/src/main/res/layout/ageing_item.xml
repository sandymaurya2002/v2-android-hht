<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="5dp" app:cardElevation="5dp" app:cardUseCompatPadding="true">
    <LinearLayout android:padding="8dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_weight="0" android:background="@color/stock_gen" android:orientation="horizontal">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Stock" android:layout_gravity="center" android:textColor="#FFF" android:textStyle="italic" android:paddingLeft="5dp" android:textSize="@dimen/header_text_size" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_weight="0" android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight=".3" android:text="ARTICLE " android:textColor="@color/buttonColortext" android:textSize="@dimen/label_text_size" />
                <EditText android:layout_marginRight="2dp" android:paddingLeft="5dp" android:id="@+id/article_et" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight=".8" android:enabled="true" android:focusable="false" android:hint="Article No" android:textSize="@dimen/text_size" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_weight="0" android:visibility="gone" android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight=".3" android:text="MAT DES. " android:textColor="@color/buttonColortext" android:textSize="@dimen/label_text_size" />
                <EditText android:layout_marginRight="2dp" android:paddingLeft="5dp" android:id="@+id/matDesc" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight=".8" android:enabled="true" android:focusable="false" android:hint="Description " android:textSize="@dimen/text_size" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_weight="0" android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight=".3" android:text="Ageing" android:textColor="@color/buttonColortext" android:textSize="@dimen/label_text_size" />
                <EditText android:layout_marginRight="2dp" android:paddingLeft="5dp" android:id="@+id/stockageing" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight=".8" android:enabled="true" android:focusable="false" android:hint="Ageing" android:textSize="@dimen/text_size" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_weight="0" android:background="@color/stock" android:orientation="horizontal">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:textStyle="italic" android:text="Sales" android:paddingLeft="5dp" android:layout_gravity="center" android:textColor="#FFF" android:textSize="@dimen/header_text_size" />
                <TextView android:id="@+id/matDesc2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight=".8" android:maxLines="3" android:singleLine="false" android:textColor="#FFF" android:gravity="center" android:textSize="@dimen/label_text_size" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_weight="0" android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight=".3" android:text="Ageing" android:textColor="@color/buttonColortext" android:textSize="@dimen/label_text_size" />
                <EditText android:layout_marginRight="2dp" android:paddingLeft="5dp" android:id="@+id/salesageing" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight=".8" android:enabled="true" android:focusable="false" android:hint="Ageing" android:textSize="@dimen/text_size" android:background="@color/bgInput" android:textColor="@color/textPrimary" android:textColorHint="@color/textHint" android:paddingStart="14dp" android:paddingEnd="14dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>